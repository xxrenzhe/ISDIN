{
  "name": "bes3-editorial",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist && cp -R dist/pagefind dist/pagefind-v20260721",
    "preview": "astro preview",
    "typecheck": "astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check:links": "node scripts/check-links.mjs",
    "check:affiliate-links": "node scripts/check-affiliate-links.mjs",
    "check:editorial-content": "node scripts/check-editorial-content.mjs",
    "check:image-review": "node scripts/check-image-review.mjs",
    "check:content-readiness": "node scripts/check-content-readiness.mjs",
    "check:public-content": "node scripts/check-public-content.mjs",
    "content:new": "node scripts/new-content.mjs",
    "deploy:pages": "node scripts/deploy-pages.mjs",
    "deploy:production": "npm run check && npm run deploy:pages -- --branch main && npm run verify:production",
    "verify:production": "node scripts/verify-production.mjs",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run check:content-readiness && npm run check:image-review && npm run build && npm run check:links && npm run check:affiliate-links && npm run check:editorial-content && npm run check:public-content"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/manrope": "^5.3.0",
    "@fontsource-variable/newsreader": "^5.3.0",
    "astro": "^7.1.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^1.7.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
