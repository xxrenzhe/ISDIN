---
import { getCollection } from "astro:content";
import CollectionIndex from "@/components/content/CollectionIndex.astro";
import { byNewest, contentArtworkKey, contentHref } from "@/utils/content";
const entries = byNewest(await getCollection("routines", ({ data }) => !data.draft));
const items = entries.map((entry) => ({
  href: contentHref(entry),
  ...entry.data,
  eyebrow: "ROUTINE GUIDE",
  artworkKey: contentArtworkKey(entry),
}));
---

<CollectionIndex
  title="Routine library"
  eyebrow="FEWER, CLEARER STEPS"
  description="Build a practical morning or evening routine around a real need rather than a crowded shelf."
  {items}
/>
