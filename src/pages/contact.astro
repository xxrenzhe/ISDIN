---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Contact BES3" description="Contact the BES3 editorial desk.">
  <section class="page-hero shell">
    <div><p class="eyebrow">CONTACT</p><h1>Send a considered note.</h1></div><p class="lede">
      Corrections, source suggestions, image permissions and commercial questions are welcome.
    </p>
  </section>
  <section class="section reading-width article-body">
    <p class="lede">
      <a class="button button--primary" href="mailto:editorial@bes3.com">Email the editorial desk</a
      >
    </p>
    <h2>Useful context</h2><p>
      Include the page URL, the specific issue and any source that helps us verify it. We do not
      accept payment in exchange for an editorial conclusion.
    </p>
  </section>
</BaseLayout>
