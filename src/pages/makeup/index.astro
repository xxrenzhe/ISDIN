---
import { getCollection } from "astro:content";
import CollectionIndex from "@/components/content/CollectionIndex.astro";
import { byNewest, contentArtworkKey, contentHref } from "@/utils/content";

const entries = byNewest(await getCollection("makeup", ({ data }) => !data.draft));
const items = entries.map((entry) => ({
  href: contentHref(entry),
  ...entry.data,
  eyebrow: "MAKEUP BASICS",
  artworkKey: contentArtworkKey(entry),
}));
---

<CollectionIndex
  title="Makeup, made clearer."
  eyebrow="COLOR, TEXTURE AND TECHNIQUE"
  description="Practical guides to complexion, color and tools that keep the choice in proportion to the result."
  layout="index"
  {items}
/>
