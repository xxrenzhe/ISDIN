---
import { getCollection } from "astro:content";
import CollectionIndex from "@/components/content/CollectionIndex.astro";
import { byNewest, contentArtworkKey, contentHref } from "@/utils/content";
const entries = byNewest(await getCollection("journal", ({ data }) => !data.draft));
const items = entries.map((entry) => ({
  href: contentHref(entry),
  ...entry.data,
  eyebrow: "EDITOR'S NOTE",
  artworkKey: contentArtworkKey(entry),
}));
---

<CollectionIndex
  title="Journal"
  eyebrow="METHODS & NOTES"
  description="A closer look at skincare claims, evidence, product language and the culture around the shelf."
  layout="journal"
  {items}
/>
