---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import heroImage from "@/assets/images/bes3-home-routine-v3.webp";
import ArticleCard from "@/components/content/ArticleCard.astro";
import EditorialArtwork from "@/components/content/EditorialArtwork.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { byNewest, contentArtworkKey, contentHref } from "@/utils/content";

const allEditorial = await Promise.all([
  getCollection("journal", ({ data }) => !data.draft),
  getCollection("ingredients", ({ data }) => !data.draft),
  getCollection("routines", ({ data }) => !data.draft),
  getCollection("product-guides", ({ data }) => !data.draft),
]);
const articles = byNewest(allEditorial.flat());
const feature = articles.find((entry) => entry.data.featured) || articles[0];
const secondary = articles.filter((entry) => entry.id !== feature?.id).slice(0, 3);
const concerns = await getCollection("concerns", ({ data }) => !data.draft);
const brandFocus = await getCollection("brand-focus", ({ data }) => !data.draft);
---

<BaseLayout
  title="BES3"
  description="Skincare, examined more clearly. Independent guides to ingredients, routines and product choices."
>
  <section class="hero shell">
    <div class="hero__copy">
      <p class="eyebrow">INDEPENDENT SKINCARE EDITORIAL</p>
      <h1>Skincare, examined more clearly.</h1>
      <p class="lede">
        Independent guides to ingredients, routines and the product choices behind healthier-looking
        skin.
      </p>
      <div class="hero__actions">
        <a class="button button--primary" href="/ingredients/">Explore the essentials</a>
        <a class="text-link" href="/how-we-evaluate/">How we evaluate skincare</a>
      </div>
    </div>
    <figure class="hero__visual">
      <Picture
        src={heroImage}
        widths={[480, 720, 960, 1280]}
        formats={["avif", "webp"]}
        sizes="(max-width: 839px) calc(100vw - 40px), 40vw"
        alt="Person applying sunscreen to their cheek in soft morning window light"
        loading="eager"
        fetchpriority="high"
      />
    </figure>
  </section>

  <section class="section section--paper">
    <div class="shell">
      <div class="section-heading">
        <div><h2>Start with what matters.</h2></div>
        <p>
          Clearer explanations for the questions that shape an effective routine—without adding more
          noise.
        </p>
      </div>
      {
        feature && (
          <ArticleCard
            href={contentHref(feature)}
            title={feature.data.title}
            description={feature.data.description}
            eyebrow={feature.data.eyebrow}
            publishDate={feature.data.publishDate}
            readTime={feature.data.readTime}
            variant="feature"
            artworkKey={contentArtworkKey(feature)}
          />
        )
      }
      <div class="card-grid home-secondary section--tight">
        {
          secondary.map((entry) => (
            <ArticleCard
              href={contentHref(entry)}
              title={entry.data.title}
              description={entry.data.description}
              eyebrow={entry.data.eyebrow}
              publishDate={entry.data.publishDate}
              readTime={entry.data.readTime}
              artworkKey={contentArtworkKey(entry)}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section shell">
    <div class="section-heading">
      <div><h2>Explore by need, not hype.</h2></div>
      <p>Find practical starting points, relevant ingredients and routines that stay manageable.</p>
    </div>
    <div class="indexed-list">
      {
        concerns.slice(0, 8).map((entry, index) => (
          <a href={contentHref(entry)}>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{entry.data.title}</strong>
            <svg viewBox="0 0 20 20" aria-hidden="true">
              <path d="M4 10h12m-5-5 5 5-5 5" />
            </svg>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section section--paper">
    <div class="feature-band shell">
      <EditorialArtwork
        artworkKey="home-brand-focus"
        compact
        label="Person applying sunscreen in natural daylight"
      />
      <div>
        <p class="eyebrow">BRAND FOCUS · 01</p>
        <h2>ISDIN: sun care, photoaging and daily skin health.</h2>
        <p>
          Our focused edit of the European skincare brand—its sun-care expertise, formulas and the
          products readers may want to understand first.
        </p>
        <a class="button button--primary" href="/brand-focus/isdin/">Explore the ISDIN feature</a>
      </div>
    </div>
    <div class="shell card-grid section--tight">
      {
        brandFocus
          .slice(0, 3)
          .map((entry) => (
            <ArticleCard
              href={contentHref(entry)}
              title={entry.data.title}
              description={entry.data.description}
              eyebrow="BRAND FOCUS · ISDIN"
              publishDate={entry.data.publishDate}
              readTime={entry.data.readTime}
              artworkKey={contentArtworkKey(entry)}
            />
          ))
      }
    </div>
  </section>

  <section class="section shell">
    <div class="standard-note">
      <div class="standard-note__lead">
        <h2>The method stays visible.</h2>
        <p>
          Recommendations are more useful when you can see how they were made—and where the limits
          are.
        </p>
      </div>
      <div class="standard-note__rules">
        <article>
          <strong>Sources, not slogans.</strong><p>
            Key claims link back to research, professional guidance or verified product information.
          </p>
        </article>
        <article>
          <strong>Commercial ties, disclosed nearby.</strong><p>
            Relationships appear beside the relevant link, not hidden in a distant footer.
          </p>
        </article>
        <article>
          <strong>Currency, kept in view.</strong><p>
            Articles carry dates and are revisited as products, evidence and guidance change.
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
