---
import { getCollection } from "astro:content";
import CollectionIndex from "@/components/content/CollectionIndex.astro";
import { byNewest, contentArtworkKey, contentHref } from "@/utils/content";
const entries = byNewest(await getCollection("brand-focus", ({ data }) => !data.draft));
const items = entries.map((entry) => ({
  href: contentHref(entry),
  ...entry.data,
  eyebrow: "BRAND FOCUS · ISDIN",
  artworkKey: contentArtworkKey(entry),
}));
---

<CollectionIndex
  title="Brand focus"
  eyebrow="EDITORIAL BRAND STUDIES"
  description="Focused brand education, product context and clearly disclosed paths to official merchant pages."
  {items}
/>
