---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="BES3 Editorial" description="The BES3 editorial desk.">
  <section class="page-hero shell">
    <div><p class="eyebrow">AUTHOR</p><h1>BES3 Editorial</h1></div><p class="lede">
      The BES3 byline for source-led research, careful editing and publication.
    </p>
  </section>
  <section class="section reading-width article-body">
    <h2>What the desk does</h2><p>
      The editorial desk researches sources, checks product information, keeps commercial
      disclosures visible and maintains review dates. Articles published under this byline are
      editorial guides, not medical advice or a substitute for care from a qualified clinician.
    </p>
  </section>
</BaseLayout>
