---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="BES3 Editorial" description="The BES3 editorial desk.">
  <section class="page-hero shell">
    <div><p class="eyebrow">AUTHOR</p><h1>BES3 Editorial</h1></div><p class="lede">
      A named editorial desk for research, editing and publishing. Individual contributors will be
      added with their real credentials as the publication grows.
    </p>
  </section>
  <section class="section reading-width article-body">
    <h2>What the desk does</h2><p>
      The editorial desk researches sources, checks product information, keeps commercial
      disclosures visible and maintains review dates. It does not present itself as a medical
      practice.
    </p>
  </section>
</BaseLayout>
