---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Search BES3"
  description="Search BES3 beauty guides and editorial notes."
  robots="noindex,follow"
>
  <section class="page-hero shell">
    <div><p class="eyebrow">FIND YOUR THREAD</p><h1>Search the archive.</h1></div><p class="lede">
      Find a skincare concern, makeup question, hair-care routine, fragrance note or brand feature
      without guessing the right category first.
    </p>
  </section>
  <section class="section section--paper">
    <div class="shell">
      <div id="search" class="search-box" aria-label="BES3 search"></div>
    </div>
  </section>
  <script is:inline src="/pagefind-v20260721/pagefind-ui.js"></script>
  <script is:inline src="/pagefind-search.js?v=20260721"></script>
</BaseLayout>
