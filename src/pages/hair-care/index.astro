---
import { getCollection } from "astro:content";
import CollectionIndex from "@/components/content/CollectionIndex.astro";
import { byNewest, contentArtworkKey, contentHref } from "@/utils/content";

const entries = byNewest(await getCollection("hair-care", ({ data }) => !data.draft));
const items = entries.map((entry) => ({
  href: contentHref(entry),
  ...entry.data,
  eyebrow: "HAIR CARE",
  artworkKey: contentArtworkKey(entry),
}));
---

<CollectionIndex
  title="Hair care, made manageable."
  eyebrow="SCALP, LENGTHS AND STYLING"
  description="Useful guidance on wash day, scalp comfort and styling habits without turning everyday care into a project."
  layout="index"
  {items}
/>
