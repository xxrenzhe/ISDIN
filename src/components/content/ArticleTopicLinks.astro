      description: "Understand the editorial method behind the guides.",
    },
  ],
  "brand-focus": [
    {
      href: "/product-guides/",
      label: "Compare product categories",
      description: "Keep brand information beside the wider shelf.",
    },
    {
      href: "/ingredients/",
      label: "Explore ingredients",
      description: "Read the formula context before a claim.",
    },
    {
      href: "/how-we-evaluate/",
      label: "See how we evaluate",
      description: "Understand the editorial method behind the guide.",
    },
  ],
