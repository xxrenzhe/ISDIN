const links = routes[collection];
---

<section class="article-topic-links" aria-labelledby="topic-links-heading">
  <p class="eyebrow">EXPLORE THE CONTEXT</p>
  <h2 id="topic-links-heading">Continue through the beauty archive.</h2>
  <p>Take the next useful route rather than treating one article as the end of the question.</p>
  <ul>
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            data-analytics-link-type="article-topic-path"
            data-analytics-label={link.label}
          >
            <strong>{link.label}</strong>
            <span>{link.description}</span>
          </a>
        </li>
      ))
    }
  </ul>
</section>
