---
import type { CollectionKey } from "astro:content";

type EditorialCollection = Exclude<CollectionKey, "authors">;

interface TopicLink {
  href: string;
  label: string;
  description: string;
}

interface Props {
  collection: EditorialCollection;
}

const { collection } = Astro.props;
const routes: Record<EditorialCollection, TopicLink[]> = {
  concerns: [
    {
      href: "/ingredients/",
      label: "Explore ingredients",
      description: "Learn what a formula can contribute.",
    },
    {
      href: "/routines/",
      label: "Build a routine",
      description: "Put the next step into a repeatable order.",
    },
    {
      href: "/product-guides/",
      label: "Compare formats",
      description: "Choose a category before adding a product.",
    },
  ],
  ingredients: [
    {
      href: "/concerns/",
      label: "Start with the concern",
      description: "Connect an ingredient to the change you notice.",
    },
    {
      href: "/routines/",
      label: "Place it in a routine",
      description: "Keep a useful sequence simple.",
    },
    {
      href: "/product-guides/",
      label: "Compare product roles",
      description: "See how formats affect everyday use.",
    },
  ],
  routines: [
    {
      href: "/concerns/",
      label: "Understand the concern",
      description: "Keep the routine tied to a real observation.",
    },
    {
      href: "/ingredients/",
      label: "Read the ingredients",
      description: "Know what each active is being asked to do.",
    },
    {
      href: "/product-guides/",
      label: "Choose the format",
      description: "Find a product role that fits your normal day.",
    },
  ],
  "product-guides": [
    {
      href: "/ingredients/",
      label: "Read the formula",
      description: "Put an ingredient list in context.",
    },
    {
      href: "/routines/",
      label: "Fit it into a routine",
      description: "Decide what the new product would replace.",
    },
    {
      href: "/concerns/",
      label: "Return to the concern",
      description: "Keep the choice proportionate to the goal.",
    },
  ],
  makeup: [
    {
      href: "/beauty/",
      label: "Browse the beauty guide",
      description: "Move between makeup, hair and fragrance coverage.",
    },
    {
      href: "/skincare/",
      label: "Prepare the base",
      description: "Find skincare context for everyday makeup.",
    },
    {
      href: "/journal/",
      label: "Read the method",
      description: "See how BES3 weighs claims and choices.",
    },
  ],
  "hair-care": [
    {
      href: "/beauty/",
      label: "Browse the beauty guide",
      description: "Move between hair, makeup and fragrance coverage.",
    },
    {
      href: "/skincare/",
      label: "Explore skin and scalp context",
      description: "Start with a practical care question.",
    },
    {
      href: "/journal/",
      label: "Read the method",
      description: "See how BES3 weighs claims and choices.",
    },
  ],
  fragrance: [
    {
      href: "/beauty/",
      label: "Browse the beauty guide",
      description: "Move between fragrance, makeup and hair coverage.",
    },
    {
      href: "/makeup/",
      label: "Explore makeup",
      description: "Find another route through personal expression.",
    },
    {
      href: "/journal/",
      label: "Read the method",
      description: "See how BES3 weighs claims and choices.",
    },
  ],
  journal: [
    {
      href: "/beauty/",
      label: "Browse the beauty guide",
      description: "Find coverage across every beauty category.",
    },
    {
      href: "/skincare/",
