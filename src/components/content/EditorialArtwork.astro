---
import { Picture } from "astro:assets";
import { getArtwork } from "@/data/article-artwork";

interface Props {
  artworkKey: string;
  label?: string;
  compact?: boolean;
}

const { artworkKey, label = "BES3 editorial photo", compact = false } = Astro.props;
const artwork = getArtwork(artworkKey);
const widths = compact ? [480, 720, 960] : [720, 960, 1280];
const sizes = compact
  ? "(max-width: 640px) calc(100vw - 40px), (max-width: 980px) calc(50vw - 32px), 33vw"
  : "(max-width: 980px) calc(100vw - 40px), min(720px, 58vw)";
---

<figure class:list={["editorial-art", { "editorial-art--compact": compact }]}>
  <Picture
    src={artwork}
    {widths}
    formats={["avif", "webp"]}
    {sizes}
    alt={label}
    loading={compact ? "lazy" : "eager"}
    decoding="async"
  />
</figure>
