---
import { Image } from "astro:assets";
import { getArtwork } from "@/data/article-artwork";

interface Props {
  artworkKey: string;
  label?: string;
  compact?: boolean;
}

const { artworkKey, label = "BES3 editorial photo", compact = false } = Astro.props;
const artwork = getArtwork(artworkKey);
---

<figure class:list={["editorial-art", { "editorial-art--compact": compact }]}>
  <Image src={artwork} alt={label} loading={compact ? "lazy" : "eager"} decoding="async" />
</figure>
