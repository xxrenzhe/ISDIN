---
import { getCollection, type CollectionEntry, type CollectionKey } from "astro:content";
import AffiliateCTA from "@/components/commercial/AffiliateCTA.astro";
import DisclosureNotice from "@/components/commercial/DisclosureNotice.astro";
import MerchantLink from "@/components/commercial/MerchantLink.astro";
import EditorialArtwork from "@/components/content/EditorialArtwork.astro";
import RelatedReading from "@/components/content/RelatedReading.astro";
import Breadcrumbs from "@/components/navigation/Breadcrumbs.astro";
import { getIsdinLink } from "@/data/affiliate-links/isdin";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { contentHref, formatDate } from "@/utils/content";

interface Props {
  entry: CollectionEntry<CollectionKey>;
}

const { entry } = Astro.props;
const data = entry.data as CollectionEntry<"journal">["data"];
const updated = data.updatedDate || data.publishDate;
const ctaLinkId = data.ctaLinkIds?.[0];
const ctaLink = ctaLinkId ? getIsdinLink(ctaLinkId) : undefined;
const articleSlug =
  entry.id
    .replace(/\.(md|mdx)$/, "")
    .split("/")
    .at(-1) || entry.id;
const collectionMeta = {
  concerns: { label: "Concerns", href: "/concerns/" },
  ingredients: { label: "Ingredients", href: "/ingredients/" },
  routines: { label: "Routines", href: "/routines/" },
  "product-guides": { label: "Product guides", href: "/product-guides/" },
  journal: { label: "Journal", href: "/journal/" },
  "brand-focus": { label: "Brand focus", href: "/brand-focus/" },
} as const;
const collection = entry.collection as keyof typeof collectionMeta;
const parent = collectionMeta[collection];
const breadcrumbs = [
  { label: "Home", href: "/" },
  ...(collection === "brand-focus" && entry.id.startsWith("isdin/")
    ? [
        { label: parent.label, href: parent.href },
        { label: "ISDIN", href: "/brand-focus/isdin/" },
      ]
    : [{ label: parent.label, href: parent.href }]),
  { label: data.title },
];
const collections = [
  "concerns",
  "ingredients",
  "routines",
  "product-guides",
  "journal",
  "brand-focus",
] as const;
const allEntries = (
  await Promise.all(
    collections.map((name) => getCollection(name, ({ data: candidate }) => !candidate.draft)),
  )
).flat();
const matchTerms = new Set([
  ...data.tags,
  ...data.concerns,
  ...data.ingredients,
  ...data.productTypes,
]);
const relatedEntries = allEntries
  .filter((candidate) => candidate.collection !== entry.collection || candidate.id !== entry.id)
  .map((candidate) => ({
    entry: candidate,
    score: [
      ...candidate.data.tags,
      ...candidate.data.concerns,
      ...candidate.data.ingredients,
      ...candidate.data.productTypes,
    ].filter((term) => matchTerms.has(term)).length,
  }))
  .sort(
    (a, b) =>
      b.score - a.score || b.entry.data.publishDate.valueOf() - a.entry.data.publishDate.valueOf(),
  )
  .slice(0, 3)
  .map(({ entry: related }) => ({
    href: contentHref(related),
    title: related.data.title,
    eyebrow: related.data.eyebrow || collectionMeta[related.collection].label,
  }));

if (data.disclosure === "affiliate" && ctaLink?.relationship !== "affiliate") {
  throw new Error(`Affiliate article requires an approved affiliate link: ${entry.id}`);
}
---

<BaseLayout
  title={data.title}
  description={data.description}
  type="article"
  article={{ publishedDate: data.publishDate, modifiedDate: updated, author: "BES3 Editorial" }}
  {breadcrumbs}
>
  <article>
    <Breadcrumbs items={breadcrumbs} />
    <header class="article-header shell">
      <p class="eyebrow">{data.eyebrow || entry.collection.replace("-", " ")}</p>
      <h1>{data.title}</h1>
      <p class="lede">{data.description}</p>
      <p class="article-header__meta">
        <span>By <a href={`/authors/${data.author}/`}>BES3 Editorial</a></span>
        <time datetime={data.publishDate.toISOString()}>{formatDate(data.publishDate)}</time>
        <span>Updated {formatDate(updated)}</span>
        <span>{data.readTime} min read</span>
      </p>
    </header>

    <div class="shell">
      <EditorialArtwork
        artworkKey={`${entry.collection}/${entry.id}`}
        label={`${data.title} editorial photo`}
      />
    </div>

    {
      data.disclosure !== "none" && (
        <div class="reading-width section--tight">
          <DisclosureNotice relationship={data.disclosure} />
        </div>
      )
    }

    <div class="article-shell shell">
      <aside class="article-aside" aria-label="Article standard">
        <p>
          <strong>BES3 standard</strong><br />Sources shown<br />Limits stated<br />Updated for
          currency
        </p>
      </aside>
      <div class="article-body">
        <slot />

        {
          ctaLinkId &&
            (data.disclosure === "affiliate" ? (
              <AffiliateCTA linkId={ctaLinkId} placement="article-end" articleSlug={articleSlug} />
            ) : (
              <MerchantLink linkId={ctaLinkId} placement="article-end" articleSlug={articleSlug} />
            ))
        }

        <RelatedReading items={relatedEntries} />

        <section class="sources" aria-labelledby="sources-heading">
          <h2 id="sources-heading">Sources</h2>
          <ol>
            {
              data.sources.map((source) => (
                <li>
                  <a href={source.url}>{source.label}</a>
                </li>
              ))
            }
          </ol>
          <p>
            <small
              >Last reviewed {formatDate(updated)}. This article is educational and does not replace
              medical advice.</small
            >
          </p>
        </section>
      </div>
      <aside class="article-aside" aria-label="Related topics">
        {
          data.ingredients.length > 0 && (
            <p>
              <br />
              {data.ingredients.join(" · ")}
            </p>
          )
        }
        {
          data.concerns.length > 0 && (
            <p>
              <br />
              {data.concerns.join(" · ")}
            </p>
          )
        }
      </aside>
    </div>
  </article>
</BaseLayout>
