---
import "@fontsource-variable/manrope";
import "@fontsource-variable/newsreader";
import Analytics from "@/components/analytics/Analytics.astro";
import SiteFooter from "@/components/navigation/SiteFooter.astro";
import SiteHeader from "@/components/navigation/SiteHeader.astro";
import { SITE } from "@/data/site";
import "@/styles/global.css";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  robots?: "noindex,follow" | "noindex,nofollow";
  type?: "website" | "article";
  pageType?: "WebPage" | "CollectionPage";
  article?: {
    publishedDate: Date;
    modifiedDate: Date;
    author: string;
    image?: string;
  };
  breadcrumbs?: Array<{ label: string; href?: string }>;
}

const {
  title,
  description = SITE.description,
  canonical = new URL(Astro.url.pathname, SITE.url).toString(),
  noindex = false,
  robots,
  type = "website",
  pageType = "WebPage",
  article,
  breadcrumbs = [],
} = Astro.props;
const fullTitle = title === SITE.name ? title : `${title} | ${SITE.name}`;
const isPreviewDeployment =
  Boolean(import.meta.env.CF_PAGES_BRANCH) && import.meta.env.CF_PAGES_BRANCH !== "main";
const robotsDirective = isPreviewDeployment
  ? "noindex,nofollow"
  : (robots ?? (noindex ? "noindex,nofollow" : undefined));
const organizationId = `${SITE.url}/#organization`;
const websiteId = `${SITE.url}/#website`;
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION?.trim();
const socialImage = article?.image
  ? new URL(article.image, SITE.url).toString()
  : `${SITE.url}/og-default.svg`;
const pageSchema = {
  "@type": type === "article" ? "Article" : pageType,
  "@id": canonical,
  name: fullTitle,
  headline: type === "article" ? title : undefined,
  description,
  url: canonical,
  mainEntityOfPage: type === "article" ? { "@id": canonical } : undefined,
  inLanguage: "en-US",
  datePublished: article?.publishedDate.toISOString(),
  dateModified: article?.modifiedDate.toISOString(),
  image: article?.image ? [socialImage] : undefined,
  author: article
    ? {
        "@type": "Organization",
        name: article.author,
        url: `${SITE.url}/authors/bes3-editorial/`,
      }
    : undefined,
  publisher: { "@id": organizationId },
  isPartOf: { "@id": websiteId },
};
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": organizationId,
      name: SITE.name,
      url: SITE.url,
      logo: `${SITE.url}/favicon.svg`,
    },
    {
      "@type": "WebSite",
      "@id": websiteId,
      name: SITE.name,
      url: SITE.url,
      inLanguage: "en-US",
      potentialAction: {
        "@type": "SearchAction",
        target: `${SITE.url}/search/?q={search_term_string}`,
        "query-input": "required name=search_term_string",
      },
    },
    pageSchema,
    ...(breadcrumbs.length > 0
      ? [
          {
            "@type": "BreadcrumbList",
            itemListElement: breadcrumbs.map((item, index) => ({
              "@type": "ListItem",
              position: index + 1,
              name: item.label,
              item: item.href ? new URL(item.href, SITE.url).toString() : canonical,
            })),
          },
        ]
      : []),
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f4f1e9" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="BES3 editorial feed" href="/rss.xml" />
    {
      googleSiteVerification && (
        <meta name="google-site-verification" content={googleSiteVerification} />
      )
    }
    {robotsDirective && <meta name="robots" content={robotsDirective} />}
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={title} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <SiteHeader />
    <main id="main-content">
      <slot />
    </main>
    <SiteFooter />
    <Analytics />
  </body>
</html>
