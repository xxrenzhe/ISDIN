# OpenAI-compatible image generation endpoint used by the local image CLI.
OPENAI_BASE_URL=https://your-openai-compatible-endpoint.example/v1
OPENAI_API_KEY=your-api-key-here

# Public Google values. Configure the same names as GitHub repository variables for production builds.
# GTM is the preferred delivery path; add your GA4 Google tag inside that GTM container.
PUBLIC_GOOGLE_SITE_VERIFICATION=your-search-console-html-verification-token
PUBLIC_GTM_ID=GTM-XXXXXXX
# Direct GA4 fallback only when GTM is intentionally not configured.
PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
